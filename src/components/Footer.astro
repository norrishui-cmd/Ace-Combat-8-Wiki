---
const year = new Date().getFullYear();
const { lang = 'en' } = Astro.props;

const englishSiteMap = [
  {
    heading: 'Core info',
    links: [
      { href: '/release-date', label: 'Release Date & Platforms' },
      { href: '/platforms', label: 'Platform Compatibility' },
      { href: '/system-requirements', label: 'System Requirements' },
      { href: '/pc', label: 'PC Guide Hub' },
      { href: '/languages', label: 'Languages' },
      { href: '/editions', label: 'Editions Compared' },
      { href: '/price', label: 'Price by Edition' },
      { href: '/faq', label: 'FAQ' },
    ],
  },
  {
    heading: 'World & story',
    links: [
      { href: '/story', label: 'Story & Setting' },
      { href: '/characters', label: 'Characters' },
      { href: '/squadrons', label: 'Squadrons & Flights' },
      { href: '/world', label: 'Factions & Locations' },
    ],
  },
  {
    heading: 'Gameplay',
    links: [
      { href: '/getting-started', label: "Getting Started" },
      { href: '/gameplay', label: 'Gameplay Systems' },
      { href: '/aircraft', label: 'Aircraft List' },
      { href: '/aircraft/compare', label: 'Compare Aircraft' },
      { href: '/ace-style-system', label: 'Ace Style System' },
      { href: '/new-mechanics', label: 'New Mechanics' },
      { href: '/superweapons', label: 'Superweapons & Bosses' },
      { href: '/multiplayer', label: 'Ace Combat Online' },
      { href: '/multiplayer/crossplay', label: 'Crossplay' },
      { href: '/multiplayer/co-op', label: 'Online Co-op' },
      { href: '/ace-pass', label: 'Ace Pass Explained' },
      { href: '/items', label: 'Items & Cosmetics' },
    ],
  },
  {
    heading: 'More',
    links: [
      { href: '/ace-combat-zero-bonus', label: 'Ace Combat Zero Bonus' },
      { href: '/preorder-bonuses', label: 'Preorder Bonuses' },
      { href: '/news', label: 'Latest News' },
      { href: '/demo', label: 'Demo & Beta Status' },
      { href: '/collectibles', label: 'Collector Items' },
      { href: '/about', label: 'About This Guide' },
    ],
  },
];
const localizedSiteMaps = {
  de: [
    { heading: 'Grundlagen', links: [
      {href:'/de/erscheinungsdatum',label:'Erscheinungsdatum'}, {href:'/de/plattformen',label:'Plattformen'},
      {href:'/de/sprachen',label:'Sprachen'}, {href:'/de/pc',label:'PC-Anforderungen'}, {href:'/de/faq',label:'FAQ'},
    ]},
    { heading: 'Welt & Figuren', links: [
      {href:'/de/charaktere',label:'Charaktere'}, {href:'/de/staffeln',label:'Staffeln'},
      {href:'/de/staffeln/joker-flight',label:'Joker Flight'}, {href:'/de/staffeln/queen-flight',label:'Queen Flight'},
      {href:'/de/welt',label:'Welt & Fraktionen'}, {href:'/de/welt/endurance',label:'Endurance'},
    ]},
    { heading: 'Gameplay', links: [
      {href:'/de/spielsysteme',label:'Gameplay-Systeme'}, {href:'/de/einsteiger-guide',label:'Einsteiger-Guide'},
      {href:'/de/gameplay/staffelzusammenstellung',label:'Staffelzusammenstellung'},
      {href:'/de/gameplay/wrack-kettenreaktionen',label:'Wrack-Kettenreaktionen'},
      {href:'/de/gameplay/superwaffen-schadenszonen',label:'Superwaffen-Schadenszonen'},
      {href:'/de/gameplay/ego-szenen',label:'Ego-Szenen'}, {href:'/de/mehrspieler',label:'Mehrspieler'},
    ]},
    { heading: 'Inhalte', links: [
      {href:'/de/gegenstaende',label:'Gegenstände & Kosmetik'}, {href:'/de/sammlerstuecke',label:'Sammlerstücke'},
      {href:'/de/vorbestellerbonus',label:'Vorbestellerbonus'}, {href:'/de/demo',label:'Demo-Status'},
    ]},
  ],
  ja: [
    { heading: '基本情報', links: [
      {href:'/ja/release-date',label:'発売日'}, {href:'/ja/platforms',label:'対応機種'},
      {href:'/ja/languages',label:'対応言語'}, {href:'/ja/pc',label:'PC版スペック'}, {href:'/ja/faq',label:'FAQ'},
    ]},
    { heading: '世界・人物', links: [
      {href:'/ja/characters',label:'登場人物'}, {href:'/ja/squadrons',label:'飛行隊'},
      {href:'/ja/squadrons/joker-flight',label:'Joker Flight'}, {href:'/ja/squadrons/queen-flight',label:'Queen Flight'},
      {href:'/ja/world',label:'世界・勢力'}, {href:'/ja/world/endurance',label:'空母Endurance'},
    ]},
    { heading: 'ゲームプレイ', links: [
      {href:'/ja/gameplay',label:'ゲームシステム'}, {href:'/ja/beginner-guide',label:'初心者ガイド'},
      {href:'/ja/gameplay/squadron-composition',label:'飛行隊編成'},
      {href:'/ja/gameplay/wreckage-chain-reactions',label:'残骸連鎖ダメージ'},
      {href:'/ja/gameplay/superweapon-damage-zones',label:'巨大兵器の攻撃範囲'},
      {href:'/ja/gameplay/first-person-scenes',label:'一人称ストーリー'}, {href:'/ja/multiplayer',label:'オンライン'},
    ]},
    { heading: 'コンテンツ', links: [
      {href:'/ja/items',label:'アイテム・コスメ'}, {href:'/ja/collectibles',label:'コレクターズアイテム'},
      {href:'/ja/preorder-bonus',label:'予約特典'}, {href:'/ja/demo',label:'体験版・ベータ情報'},
    ]},
  ],
};
const siteMap = lang === 'de' ? localizedSiteMaps.de : lang === 'ja' ? localizedSiteMaps.ja : englishSiteMap;
---
<footer class="site-footer">
  <div class="container">
    <nav class="site-index" aria-label="Site index">
      {siteMap.map((group) => (
        <div class="site-index__group">
          <p class="mono site-index__heading">{group.heading}</p>
          <ul>
            {group.links.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </nav>

    <div class="site-footer__inner">
      {lang !== 'en' && <p class="mono"><a href="/">English</a> · <a href="/de">Deutsch</a> · <a href="/ja">日本語</a></p>}
      <p class="mono">
        This is an unofficial fan guide. ACE COMBAT 8: WINGS OF THEVE™ &amp; © Bandai Namco Entertainment Inc.
        Not affiliated with or endorsed by Bandai Namco Entertainment Inc.
        <a href="/about">About this guide &amp; how we source information</a>.
      </p>
      <p class="mono">&copy; {year} AC8 Wings of Theve Guide</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: var(--border-thin);
    margin-top: 80px;
    padding: 40px 0 32px;
  }
  .site-index {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 24px;
    padding-bottom: 32px;
    margin-bottom: 32px;
    border-bottom: var(--border-thin);
  }
  .site-index__heading {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--radar-green);
    margin: 0 0 12px;
  }
  .site-index__group ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .site-index__group a {
    font-size: 0.82rem;
    color: var(--text-secondary);
  }
  .site-index__group a:hover {
    color: var(--hud-amber);
    text-decoration: none;
  }
  .site-footer__inner p {
    font-size: 0.72rem;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 0 8px;
  }
</style>
