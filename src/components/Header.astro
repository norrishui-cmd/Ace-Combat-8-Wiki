---
const navItems = [
  { href: '/aircraft', label: 'Aircraft' },
  { href: '/aircraft/compare', label: 'Compare' },
  { href: '/platforms', label: 'Platforms' },
  { href: '/story', label: 'Story' },
  { href: '/editions', label: 'Editions' },
  { href: '/multiplayer', label: 'Multiplayer' },
  { href: '/faq', label: 'FAQ' },
];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand">
      <span class="brand__mark">AC8</span>
      <span class="brand__text">WINGS OF THEVE GUIDE</span>
    </a>
    <nav class="site-nav">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: var(--border-thin);
    background: rgba(11, 18, 32, 0.85);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    padding-bottom: 16px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .brand {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .brand__mark {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--hud-amber);
    border: 1px solid var(--hud-amber-dim);
    padding: 2px 6px;
    font-size: 0.85rem;
    border-radius: 2px;
  }
  .brand__text {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.08em;
    font-size: 1rem;
    color: var(--text-primary);
  }
  .site-nav {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
  }
  .site-nav a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .site-nav a:hover {
    color: var(--hud-amber);
    text-decoration: none;
  }
</style>
