---
const { lang = 'en' } = Astro.props;
const navSets = { en: [
  { href: '/aircraft', label: 'Aircraft' },
  { href: '/gameplay', label: 'Gameplay' },
  { href: '/platforms', label: 'Platforms' },
  { href: '/characters', label: 'Characters' },
  { href: '/items', label: 'Items' },
  { href: '/world', label: 'World' },
  { href: '/story', label: 'Story' },
  { href: '/editions', label: 'Editions' },
  { href: '/faq', label: 'FAQ' },
], de: [
  { href: '/de/plattformen', label: 'Plattformen' }, { href: '/de/spielsysteme', label: 'Gameplay' },
  { href: '/de/charaktere', label: 'Charaktere' }, { href: '/de/mehrspieler', label: 'Mehrspieler' },
  { href: '/de/faq', label: 'FAQ' },
], ja: [
  { href: '/ja/platforms', label: '対応機種' }, { href: '/ja/gameplay', label: 'ゲームプレイ' },
  { href: '/ja/characters', label: '登場人物' }, { href: '/ja/multiplayer', label: 'オンライン' },
  { href: '/ja/faq', label: 'FAQ' },
]};
const navItems = navSets[lang] || navSets.en;
const home = lang === 'de' ? '/de' : lang === 'ja' ? '/ja' : '/';
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href={home} class="brand">
      <span class="brand__mark">AC8</span>
      <span class="brand__text">WINGS OF THEVE GUIDE</span>
    </a>
    <nav class="site-nav">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
    <nav class="language-nav" aria-label="Language"><a href="/">EN</a><a href="/de">DE</a><a href="/ja">日本語</a></nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: var(--border-thin);
    background: rgba(11, 18, 32, 0.85);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    padding-bottom: 16px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .brand {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .brand__mark {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--hud-amber);
    border: 1px solid var(--hud-amber-dim);
    padding: 2px 6px;
    font-size: 0.85rem;
    border-radius: 2px;
  }
  .brand__text {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.08em;
    font-size: 1rem;
    color: var(--text-primary);
  }
  .site-nav {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
  }
  .site-nav a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .site-nav a:hover {
    color: var(--hud-amber);
    text-decoration: none;
  }
  .language-nav { display:flex; gap:8px; margin-left:auto; }
  .language-nav a { font: .68rem var(--font-mono); color:var(--text-secondary); border:var(--border-thin); padding:3px 6px; }
</style>
