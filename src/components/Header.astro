---
import { localizedGuides } from '../data/localizedGuides';
const { lang = 'en' } = Astro.props;
const navSets = { en: [
  { href: '/aircraft', label: 'Aircraft' },
  { href: '/gameplay', label: 'Gameplay' },
  { href: '/platforms', label: 'Platforms' },
  { href: '/characters', label: 'Characters' },
  { href: '/items', label: 'Items' },
  { href: '/world', label: 'World' },
  { href: '/story', label: 'Story' },
  { href: '/editions', label: 'Editions' },
  { href: '/faq', label: 'FAQ' },
], de: [
  { href: '/de/plattformen', label: 'Plattformen' }, { href: '/de/spielsysteme', label: 'Gameplay' },
  { href: '/de/charaktere', label: 'Charaktere' }, { href: '/de/mehrspieler', label: 'Mehrspieler' },
  { href: '/de/gegenstaende', label: 'Gegenstände' }, { href: '/de/welt', label: 'Welt' },
  { href: '/de/faq', label: 'FAQ' },
], ja: [
  { href: '/ja/platforms', label: '対応機種' }, { href: '/ja/gameplay', label: 'ゲームプレイ' },
  { href: '/ja/characters', label: '登場人物' }, { href: '/ja/multiplayer', label: 'オンライン' },
  { href: '/ja/items', label: 'アイテム' }, { href: '/ja/world', label: '世界' },
  { href: '/ja/faq', label: 'FAQ' },
]};
const navItems = navSets[lang] || navSets.en;
const home = lang === 'de' ? '/de' : lang === 'ja' ? '/ja' : '/';
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const currentLocalized = localizedGuides.find((g) => `/${g.locale}${g.slug ? `/${g.slug}` : ''}` === currentPath);
const englishPath = lang === 'en' ? currentPath : currentLocalized?.englishPath || '/';
const translatedPath = (locale: 'de' | 'ja') => {
  const match = localizedGuides.find((g) => g.locale === locale && g.englishPath === englishPath);
  return match ? `/${locale}${match.slug ? `/${match.slug}` : ''}` : `/${locale}`;
};
const languageOptions = [
  { code: 'en', label: 'English', short: 'EN', href: englishPath },
  { code: 'de', label: 'Deutsch', short: 'DE', href: translatedPath('de') },
  { code: 'ja', label: '日本語', short: '日本語', href: translatedPath('ja') },
];
const activeLanguage = languageOptions.find((option) => option.code === lang) || languageOptions[0];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href={home} class="brand">
      <span class="brand__mark">AC8</span>
      <span class="brand__text">WINGS OF THEVE GUIDE</span>
    </a>
    <nav class="site-nav">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
    <details class="language-menu">
      <summary aria-label="Choose language"><span aria-hidden="true">◎</span> {activeLanguage.short}<span class="chevron" aria-hidden="true">▾</span></summary>
      <nav class="language-menu__list" aria-label="Language">
        {languageOptions.map((option) => (
          <a href={option.href} lang={option.code} hreflang={option.code} aria-current={option.code === lang ? 'page' : undefined}>
            <span>{option.label}</span><span class="mono">{option.code === lang ? '●' : option.short}</span>
          </a>
        ))}
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    border-bottom: var(--border-thin);
    background: rgba(11, 18, 32, 0.85);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    padding-bottom: 16px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .brand {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .brand__mark {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--hud-amber);
    border: 1px solid var(--hud-amber-dim);
    padding: 2px 6px;
    font-size: 0.85rem;
    border-radius: 2px;
  }
  .brand__text {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.08em;
    font-size: 1rem;
    color: var(--text-primary);
  }
  .site-nav {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
  }
  .site-nav a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .site-nav a:hover {
    color: var(--hud-amber);
    text-decoration: none;
  }
  .language-menu { position:relative; margin-left:auto; }
  .language-menu summary { list-style:none; cursor:pointer; min-width:80px; border:var(--border-thin); padding:7px 10px; color:var(--text-secondary); font:.7rem var(--font-mono); letter-spacing:.06em; display:flex; align-items:center; justify-content:space-between; gap:7px; }
  .language-menu summary::-webkit-details-marker { display:none; }
  .language-menu summary:hover, .language-menu[open] summary { color:var(--hud-amber); border-color:var(--hud-amber-dim); }
  .chevron { transition:transform .15s ease; }
  .language-menu[open] .chevron { transform:rotate(180deg); }
  .language-menu__list { position:absolute; right:0; top:calc(100% + 8px); min-width:180px; padding:6px; display:grid; gap:2px; background:rgba(11,18,32,.98); border:var(--border-thin); box-shadow:0 16px 32px rgba(0,0,0,.32); z-index:80; }
  .language-menu__list a { display:flex; justify-content:space-between; gap:24px; padding:9px 10px; color:var(--text-secondary); font-size:.78rem; text-decoration:none; }
  .language-menu__list a:hover { color:var(--hud-amber); background:rgba(255,255,255,.04); }
  .language-menu__list a[aria-current="page"] { color:var(--text-primary); }
  .language-menu__list .mono { font-size:.65rem; color:var(--radar-green); }
  @media(max-width:760px){
    .site-nav{order:3;width:100%;gap:14px;overflow-x:auto;flex-wrap:nowrap;padding-bottom:3px}.site-nav a{white-space:nowrap}.language-menu{margin-left:0}.brand__text{font-size:.84rem}.language-menu__list{position:fixed;right:16px;top:68px}}
</style>
