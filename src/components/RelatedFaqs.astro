---
import {getFaqs,faqCategoryMeta,type FaqCategory} from '../data/faqGuides';
const {category,heading=`${faqCategoryMeta[category].label} FAQ`}=Astro.props as {category:FaqCategory;heading?:string}; const items=getFaqs(category).slice(0,5);
---
<section class="container related-faqs" aria-labelledby={`faq-${category}`}><div class="head"><div><span class="eyebrow">Player questions, official answers</span><h2 id={`faq-${category}`}>{heading}</h2></div><a class="mono" href={`/faq#${category}`}>View all related FAQ →</a></div><div class="grid">{items.map(item=><a class="card" href={`/faq/${item.slug}`}><h3>{item.question}</h3><p>{item.answer}</p><span class="mono">Read complete answer →</span></a>)}</div></section>
<style>.related-faqs{padding:48px 0 24px}.head{display:flex;justify-content:space-between;align-items:end;gap:18px;margin-bottom:22px}.head h2{margin:6px 0 0}.head>a{font-size:.72rem}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:16px}.card{color:var(--text-primary);text-decoration:none}.card h3{font-size:1rem}.card p{font-size:.84rem}.card span{color:var(--hud-amber);font-size:.7rem}@media(max-width:600px){.head{align-items:start;flex-direction:column}}</style>
