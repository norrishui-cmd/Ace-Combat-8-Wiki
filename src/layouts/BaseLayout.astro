---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localizedGuides } from '../data/localizedGuides';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  bareTitle?: boolean; // true 时不自动拼接站点后缀，用于首页等已自成一句的标题
  lang?: 'en' | 'de' | 'ja';
  alternates?: { lang: string; href: string }[];
}
const { title, description, ogImage = '/og/og-default.png', noindex = false, bareTitle = false, lang = 'en', alternates = [] } = Astro.props;

// canonical URL 用 Astro.site + 当前路径自动拼，页面不用手动传，
// 避免像/aircraft和/aircraft/两个版本被当成重复内容收录。
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const englishPath = lang === 'en' ? Astro.url.pathname : localizedGuides.find((g) => `/${g.locale}${g.slug ? `/${g.slug}` : ''}` === Astro.url.pathname.replace(/\/$/, ''))?.englishPath;
const automaticAlternates = englishPath ? [
  { lang: 'en', href: englishPath },
  ...localizedGuides.filter((g) => g.englishPath === englishPath).map((g) => ({ lang: g.locale, href: `/${g.locale}${g.slug ? `/${g.slug}` : ''}` })),
  { lang: 'x-default', href: englishPath },
] : [];
const pageAlternates = alternates.length ? alternates : automaticAlternates;
const ogImageURL = new URL(ogImage, Astro.site);
const fullTitle = bareTitle ? title : `${title} | AC8 Wiki`;
const safeDescription = description.length > 165
  ? `${description.slice(0, 161).replace(/\s+\S*$/, '')}…`
  : description;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0B1220" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />
  {pageAlternates.map((alternate) => <link rel="alternate" hreflang={alternate.lang} href={new URL(alternate.href, Astro.site)} />)}
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />

  <title>{fullTitle}</title>
  <meta name="description" content={safeDescription} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Ace Combat 8: Wings of Theve Guide" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={safeDescription} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content={lang === 'de' ? 'de_DE' : lang === 'ja' ? 'ja_JP' : 'en_US'} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={safeDescription} />
  <meta name="twitter:image" content={ogImageURL} />

  <!-- Site-level structured data: tells search engines what game this site is about -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Ace Combat 8: Wings of Theve Guide',
    url: Astro.site,
    description: 'Unofficial guide to Ace Combat 8: Wings of Theve — aircraft, editions, mechanics, and multiplayer.',
    about: {
      '@type': 'VideoGame',
      name: 'Ace Combat 8: Wings of Theve',
      applicationCategory: 'Game',
      operatingSystem: 'PlayStation 5, Xbox Series X|S, Windows',
      genre: 'Flight shooter',
      gamePlatform: ['PlayStation 5', 'Xbox Series X|S', 'Windows PC'],
      publisher: {
        '@type': 'Organization',
        name: 'Bandai Namco Entertainment',
      },
      datePublished: '2026-10-02',
      sameAs: 'https://www.bandainamcoent.com/games/ace-combat-8',
    },
  })} />
</head>
<body>
  <Header lang={lang} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
