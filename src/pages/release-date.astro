---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RelatedLinks from '../components/RelatedLinks.astro';

const faqs = [
  {
    q: 'What time does Ace Combat 8 unlock on release day?',
    a: 'The global release date is October 2, 2026. PlayStation lists October 1 at 3:00 PM PT / 6:00 PM ET, October 2 at 12:00 AM CEST, and October 2 at 7:00 AM JST. Check your own store countdown for the final platform and regional timing.',
  },
  {
    q: 'Is Deluxe Edition early access worth buying just for the head start?',
    a: 'Early access gets you three extra days (from September 28) before the October 2 global launch. If avoiding spoilers matters to you and you were already leaning toward Deluxe for the Premium Ace Pass Plus voucher, the early access is a bonus rather than a separate purchase decision.',
  },
];
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout
  title="Release Date & Platforms"
  description="Ace Combat 8: Wings of Theve releases October 2, 2026 on PS5, Xbox Series X|S, and PC. Deluxe Edition early access begins September 28. Full platform and regional details."
>
  <Breadcrumbs items={[{ label: 'Release Date' }]} />
  <article class="container article">
    <span class="eyebrow">Confirmed by Bandai Namco</span>
    <h1>Release Date &amp; Platforms</h1>

    <div class="card release-card">
      <div class="release-card__row">
        <span class="mono">Global release</span>
        <span class="mono release-card__value">October 2, 2026</span>
      </div>
      <div class="release-card__row">
        <span class="mono">Deluxe early access</span>
        <span class="mono release-card__value">September 28, 2026 · 3:00 PM PDT</span>
      </div>
      <div class="release-card__row">
        <span class="mono">Platforms</span>
        <span class="mono release-card__value">PS5 · Xbox Series X|S · PC (Steam)</span>
      </div>
      <div class="release-card__row">
        <span class="mono">VR / PSVR2</span>
        <span class="mono release-card__value">Not announced</span>
      </div>
    </div>

    <h2>VR and PSVR2 status</h2>
    <p>
      Bandai Namco and the PlayStation Store do not list a VR or PSVR2 mode as of July 17,
      2026. First-person story cinematics are a confirmed presentation feature, but they do not
      establish headset support. Treat VR as unannounced unless the publisher adds it to the
      official feature list.
    </p>

    <h2>North America vs Europe timing</h2>
    <p>
      PlayStation lists October 1 at 3:00 PM PT / 6:00 PM ET, October 2 at 12:00 AM CEST,
      and October 2 at 7:00 AM JST. Steam currently displays October 1 in the US storefront.
      Use the countdown in your own platform store as the final regional check.
    </p>

    <h2>Frequently asked</h2>
    <div class="faq-list">
      {faqs.map((f) => (
        <div class="card">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <RelatedLinks items={[
    { href: '/platforms', label: 'Platform Compatibility', desc: 'PS5, Xbox, PC, old-gen, Switch 2 and Steam Deck status.' },
    { href: '/editions', label: 'Editions Compared', desc: 'Standard vs Deluxe vs Joker Flight Pack, side by side.' },
    { href: '/aircraft', label: 'Aircraft List', desc: 'Every confirmed aircraft, updated as Bandai Namco reveals more.' },
  ]} />
</BaseLayout>

<style>
  .article { padding: 56px 0 80px; max-width: 720px; }
  .article p, .article li { font-size: 0.98rem; }
  .release-card { margin: 24px 0 32px; display: grid; gap: 12px; }
  .release-card__row {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 0.85rem;
    padding-bottom: 12px;
    border-bottom: var(--border-thin);
  }
  .release-card__row:last-child { border-bottom: none; padding-bottom: 0; }
  .release-card__value { color: var(--hud-amber); }
  .faq-list { display: grid; gap: 14px; margin-top: 16px; }
  .faq-list h3 { font-size: 1rem; margin-bottom: 8px; }
  .faq-list p { font-size: 0.9rem; margin: 0; }
</style>
