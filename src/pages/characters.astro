---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import TabNews from '../components/TabNews.astro';
import { characterGuides } from '../data/characterGuides';

const groups = ['Joker Flight', 'Queen Flight', 'Endurance Crew'];
const itemListJsonLd = {
  '@context': 'https://schema.org', '@type': 'ItemList', name: 'Ace Combat 8 characters',
  itemListElement: characterGuides.map((character, index) => ({
    '@type': 'ListItem', position: index + 1, name: character.name,
    url: new URL(`/characters/${character.slug}`, Astro.site).href,
  })),
};
---
<BaseLayout
  title="Characters — Joker Flight & Endurance Crew"
  description="Official Ace Combat 8 character roster: Jan Cope, Baxter, Tasha, Coster, Kate Evans, Jessica Pike, David Jenkins and Adelina Santos with roles and callsigns."
>
  <Breadcrumbs items={[{ label: 'Characters' }]} />
  <article class="container article article--wide">
    <span class="eyebrow">Official roster checked July 18, 2026</span>
    <h1>Ace Combat 8 Characters</h1>
    <p class="direct-answer" data-concrete-answer>
      Joker Flight begins with Jan Cope as the original Wings of Theve, followed by Ellington
      Baxter, Tasha Severskya and William Coster. The Endurance roster also includes Queen Flight
      leader Kate Evans, executive officer Jessica Pike, chief mechanic David Jenkins and doctor
      Adelina Santos. The player later inherits the Wings of Theve identity.
    </p>

    {groups.map((group) => (
      <section>
        <h2>{group}</h2>
        <div class="character-grid">
          {characterGuides.filter((character) => character.group === group).map((character) => (
            <a class="card character-card" href={`/characters/${character.slug}`}>
              <span class="badge badge--confirmed">{character.role}</span>
              <h3>{character.name}{character.callsign ? ` — “${character.callsign}”` : ''}</h3>
              <p>{character.answer}</p>
              <span class="mono card-link">Read profile →</span>
            </a>
          ))}
        </div>
      </section>
    ))}

    <h2>Who is the player character?</h2>
    <p>
      The player begins as a rescued pilot and is pulled into the manufactured Wings of Theve
      legend after the original figurehead falls. Bandai Namco’s official roster names the
      original leader Jan Cope, while PlayStation’s hands-on account calls that figurehead Rex and
      says the player takes over the Rex callsign. The player remains distinct from the eight
      named roster profiles above.
    </p>
  </article>
  <TabNews category="characters" />
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <RelatedLinks items={[
    { href: '/story', label: 'Story & Setting', desc: 'The FCU collapse, Sotoan invasion and manufactured ace legend.' },
    { href: '/gameplay/wingman-commands', label: 'Wingman Commands', desc: 'How the player leads Joker Flight in combat.' },
    { href: '/ace-style-system', label: 'Ace Style', desc: 'How choices shape the pilot identity and story.' },
  ]} />
</BaseLayout>

<style>
  .article { padding: 56px 0 64px; }
  .article--wide { max-width: 1000px; }
  .direct-answer { max-width: 800px; font-size: 1.08rem; border-left: 3px solid var(--hud-amber); padding-left: 18px; }
  .article h2 { margin-top: 44px; }
  .character-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; }
  .character-card { color: var(--text-primary); text-decoration: none; }
  .character-card:hover { text-decoration: none; }
  .character-card h3 { margin-top: 14px; font-size: 1.1rem; }
  .character-card p { font-size: .88rem; }
  .card-link { color: var(--hud-amber); font-size: .74rem; }
</style>
