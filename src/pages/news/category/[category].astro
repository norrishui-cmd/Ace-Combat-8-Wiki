---
import BaseLayout from '../../../layouts/BaseLayout.astro'; import Breadcrumbs from '../../../components/Breadcrumbs.astro'; import RelatedLinks from '../../../components/RelatedLinks.astro'; import {newsCategories,getTabNews} from '../../../data/tabNews';
export function getStaticPaths(){return Object.keys(newsCategories).map(category=>({params:{category},props:{category}}))} const {category}=Astro.props; const meta=newsCategories[category]; const items=getTabNews(category); const list={'@context':'https://schema.org','@type':'ItemList',name:`Ace Combat 8 ${meta.label} updates`,itemListElement:items.map((x,i)=>({'@type':'ListItem',position:i+1,name:x.title,url:new URL(`/news/${x.category}/${x.slug}`,Astro.site).href}))};
---
<BaseLayout title={`${meta.label} News & Confirmed Updates`} description={`Five evidence-checked Ace Combat 8 ${meta.label.toLowerCase()} updates, each sourced from official Bandai Namco, PlayStation or Steam information.`}><Breadcrumbs items={[{label:'News',href:'/news'},{label:meta.label}]} /><article class="container article"><span class="eyebrow">Topic news desk</span><h1>Ace Combat 8 {meta.label} Updates</h1><p class="direct-answer" data-concrete-answer>This desk contains five distinct {meta.label.toLowerCase()} reports. Every article links to a primary source, separates confirmed facts from open questions and connects back to the relevant guide hub.</p><div class="list">{items.map(item=><a class="card" href={`/news/${item.category}/${item.slug}`}><p class="mono">{item.publishedAt}</p><h2>{item.title}</h2><p>{item.summary}</p><span class="mono">Read report →</span></a>)}</div></article><script type="application/ld+json" set:html={JSON.stringify(list)} /><RelatedLinks items={[{href:meta.hub,label:`${meta.label} Guide Hub`,desc:'Open the evergreen guide behind these updates.'},{href:'/news',label:'All News',desc:'Browse every Ace Combat 8 news category.'}]} /></BaseLayout>
<style>.article{padding:56px 0 72px;max-width:900px}.direct-answer{max-width:760px;border-left:3px solid var(--hud-amber);padding-left:18px}.list{display:grid;gap:16px;margin-top:28px}.list a{color:var(--text-primary);text-decoration:none}.list h2{font-size:1.1rem}.list p{font-size:.88rem}.list .mono{color:var(--hud-amber);font-size:.7rem}</style>
