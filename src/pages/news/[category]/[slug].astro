---
import BaseLayout from '../../../layouts/BaseLayout.astro'; import Breadcrumbs from '../../../components/Breadcrumbs.astro'; import RelatedLinks from '../../../components/RelatedLinks.astro'; import {tabNews,newsCategories} from '../../../data/tabNews';
export function getStaticPaths(){return tabNews.map(item=>({params:{category:item.category,slug:item.slug},props:{item}}))} const {item}=Astro.props; const cat=newsCategories[item.category];
const schema={'@context':'https://schema.org','@type':'NewsArticle',headline:item.title,description:item.summary,datePublished:item.publishedAt,dateModified:'2026-07-19',mainEntityOfPage:new URL(Astro.url.pathname,Astro.site).href,isBasedOn:item.sourceUrl,author:{'@type':'Organization',name:'AC8 Wiki News Desk'},publisher:{'@type':'Organization',name:'AC8 Wiki'}};
---
<BaseLayout title={item.title} description={item.summary}><Breadcrumbs items={[{label:'News',href:'/news'},{label:cat.label,href:`/news/category/${item.category}`},{label:item.title}]} /><article class="container article"><p class="mono eyebrow">Official update · Published {item.publishedAt} · Reviewed 2026-07-19</p><h1>{item.title}</h1><p class="direct-answer" data-concrete-answer>{item.answer}</p><section><h2>What the official material confirms</h2><p>{item.confirmed}</p></section><section><h2>Why this matters to players</h2><p>{item.impact}</p></section><section><h2>What is still unconfirmed</h2><p>{item.open}</p></section><aside class="source"><p class="mono">Primary source</p><a href={item.sourceUrl} rel="nofollow">{item.sourceLabel}</a><p>This is an independent guide-site summary, not a Bandai Namco press release. Claims are limited to the linked primary source.</p></aside></article><script type="application/ld+json" set:html={JSON.stringify(schema)} /><RelatedLinks items={[{href:cat.hub,label:`${cat.label} Hub`,desc:`Return to the complete ${cat.label.toLowerCase()} guide and its five latest updates.`},{href:`/news/category/${item.category}`,label:`All ${cat.label} Updates`,desc:'Browse every evidence-checked report in this topic.'},{href:'/news',label:'All Ace Combat 8 News',desc:'See updates across every guide category.'}]} /></BaseLayout>
<style>.article{padding:56px 0 72px;max-width:760px}.article h1{margin-top:8px}.article h2{margin-top:38px}.direct-answer{font-size:1.08rem;border-left:3px solid var(--hud-amber);padding-left:18px}.source{margin-top:42px;padding-top:20px;border-top:var(--border-thin)}.source p{font-size:.82rem}</style>
