---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('news');
  return all.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const dateLabel = d.publishedAt.toISOString().slice(0, 10);
---
<BaseLayout title={d.title} description={d.summary}>
  <Breadcrumbs items={[{ label: 'News', href: '/news' }, { label: d.title }]} />
  <article class="container article">
    <p class="mono eyebrow">{dateLabel}{d.sourceLabel ? ` · Source: ${d.sourceLabel}` : ''}</p>
    <h1>{d.title}</h1>
    <div class="article__body">
      <Content />
    </div>
    <a href="/news" class="btn btn--ghost">&larr; Back to news</a>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'NewsArticle',
    headline: d.title,
    description: d.summary,
    datePublished: d.publishedAt.toISOString(),
    dateModified: d.publishedAt.toISOString(),
    ...(d.sourceUrl ? { isBasedOn: d.sourceUrl } : {}),
  })} />

  <RelatedLinks items={[
    { href: '/aircraft', label: 'Aircraft List', desc: 'Full roster of confirmed aircraft with unlock methods.' },
    { href: '/news', label: 'All News', desc: 'Every confirmed reveal, tracked as it happens.' },
  ]} />
</BaseLayout>

<style>
  .article {
    padding: 56px 0 60px;
    max-width: 720px;
  }
  .article h1 { margin-top: 6px; }
  .article__body { margin: 24px 0 32px; font-size: 0.98rem; }
  .article__body :global(h2) { font-size: 1.15rem; margin-top: 28px; }
  .article__body :global(p) { color: var(--text-secondary); }
  .article__body :global(ul) { padding-left: 20px; color: var(--text-secondary); }
  .article__body :global(li) { margin-bottom: 6px; }
</style>
