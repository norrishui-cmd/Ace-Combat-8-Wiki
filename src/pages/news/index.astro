---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { tabNews, newsCategories } from '../../data/tabNews';

const posts = (await getCollection('news')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---
<BaseLayout
  title="Latest News"
  description="Every confirmed Ace Combat 8: Wings of Theve announcement, reveal, and update — tracked as Bandai Namco releases new information ahead of the October 2, 2026 launch."
>
  <Breadcrumbs items={[{ label: 'News' }]} />
  <section class="container page-head">
    <span class="eyebrow">Updated as Bandai Namco announces</span>
    <h1>Latest News</h1>
    <p>
      Every confirmed reveal, tracked close to when it happens. News posts record what changed;
      evergreen guides turn the confirmed information into direct answers for players.
    </p>
  </section>

  <section class="container news-list">
    {posts.map((p) => (
      <a href={`/news/${p.id}`} class="card news-item">
        <p class="mono news-item__date">{p.data.publishedAt.toISOString().slice(0, 10)}</p>
        <h2>{p.data.title}</h2>
        <p class="news-item__summary">{p.data.summary}</p>
      </a>
    ))}
  </section>
  <section class="container topic-desks">
    <span class="eyebrow">Five reports per guide tab</span>
    <h2>Browse News by Topic</h2>
    <div class="card-grid">
      {Object.entries(newsCategories).map(([key, category]) => (
        <a class="card desk" href={`/news/category/${key}`}>
          <h3>{category.label} News</h3>
          <p>Five official-source updates connected to the {category.label} guide.</p>
          <span class="mono">Open desk →</span>
        </a>
      ))}
    </div>
  </section>
  <section class="container news-list expanded">
    <h2>All Topic Updates</h2>
    {tabNews.map((p) => (
      <a href={`/news/${p.category}/${p.slug}`} class="card news-item">
        <p class="mono news-item__date">{p.publishedAt} · {newsCategories[p.category].label}</p>
        <h2>{p.title}</h2><p class="news-item__summary">{p.summary}</p>
      </a>
    ))}
  </section>
  <section class="container news-policy">
    <h2>How updates become guide changes</h2>
    <p>
      We prioritize Bandai Namco, Project Aces, Steam and platform-holder announcements. A new
      aircraft, mode or mechanic is added to the relevant database only when the source identifies
      it clearly. Trailer interpretation and retailer placeholders stay labeled as unconfirmed
      instead of being converted into permanent wiki facts.
    </p>
    <p>
      For the latest confirmed systems, use the <a href="/gameplay">gameplay hub</a>, the
      <a href="/multiplayer">Ace Combat Online guide</a>, or the
      <a href="/aircraft">aircraft database</a>. These pages are updated when a news item changes
      a player-facing answer.
    </p>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding: 56px 0 32px;
    max-width: 720px;
  }
  .news-list {
    display: grid;
    gap: 16px;
    padding-bottom: 80px;
  }
  .news-item {
    display: block;
    text-decoration: none;
    color: var(--text-primary);
  }
  .news-item:hover { text-decoration: none; border-color: var(--hud-amber-dim); }
  .news-item__date {
    font-size: 0.72rem;
    color: var(--radar-green);
    margin: 0 0 6px;
  }
  .news-item h2 { font-size: 1.15rem; margin: 0 0 8px; }
  .news-item__summary { font-size: 0.9rem; margin: 0; }
  .news-policy { max-width: 760px; padding: 16px 24px 64px; }
  .topic-desks { padding-bottom:48px; }
  .topic-desks h2 { margin-top:8px; }
  .desk { color:var(--text-primary); text-decoration:none; }
  .desk h3 { font-size:1rem; }.desk p{font-size:.84rem}.desk .mono{color:var(--hud-amber);font-size:.7rem}
  .expanded { padding-bottom:48px; }
</style>
