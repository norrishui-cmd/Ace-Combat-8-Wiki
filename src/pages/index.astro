---
import BaseLayout from '../layouts/BaseLayout.astro';
import HudStrip from '../components/HudStrip.astro';
import CountdownHero from '../components/CountdownHero.astro';

const navCards = [
  {
    href: '/news',
    label: 'Latest News',
    desc: 'Every confirmed reveal and update, tracked close to when it happens.',
  },
  {
    href: '/platforms',
    label: 'Platforms & Compatibility',
    desc: 'PS5, Xbox, PC, PS4, Switch 2 and Steam Deck status, checked against official sources.',
  },
  {
    href: '/gameplay',
    label: 'Gameplay Systems',
    desc: 'Upgrades, special weapons, wingman commands, MRP, briefings, high-G turns and weather.',
  },
  {
    href: '/getting-started',
    label: "Getting Started",
    desc: 'New to the series? What\'s actually different (and easier) in Wings of Theve.',
  },
  {
    href: '/aircraft',
    label: 'Aircraft List',
    desc: '30+ playable aircraft across four categories — updated as new confirmations drop.',
  },
  {
    href: '/aircraft/compare',
    label: 'Compare Aircraft',
    desc: 'Put up to 4 aircraft head-to-head — speed, mobility, firepower, and more.',
  },
  {
    href: '/story',
    label: 'Story & Setting',
    desc: 'The FCU, the Sotoa invasion, and what "Wings of Theve" really means.',
  },
  {
    href: '/characters',
    label: 'Characters',
    desc: 'Official profiles for Jan Cope, Joker Flight, FCU commanders and Sotoan rivals.',
  },
  {
    href: '/superweapons',
    label: 'Superweapons & Bosses',
    desc: 'The 450-meter Land Battleship, and every boss encounter confirmed so far.',
  },
  {
    href: '/editions',
    label: 'Editions & Pre-order',
    desc: 'Standard vs Deluxe vs Joker Flight Pack, and what each bonus actually unlocks.',
  },
  {
    href: '/price',
    label: 'Price by Edition',
    desc: 'Current Standard, Deluxe and Joker Flight Pack prices with regional context.',
  },
  {
    href: '/ace-style-system',
    label: 'Ace Style System',
    desc: 'How your in-mission choices shape your pilot identity and the story outcome.',
  },
  {
    href: '/new-mechanics',
    label: 'New Mechanics',
    desc: 'Debris damage, dual special weapons, no more weak-point-only hits, and more.',
  },
  {
    href: '/multiplayer',
    label: 'Ace Combat Online',
    desc: "The franchise's largest multiplayer mode — lobby, avatars, cross-platform play.",
  },
  {
    href: '/ace-pass',
    label: 'Ace Pass Explained',
    desc: 'Free, Premium and Premium Plus tiers, the 30-level skip and Season 1 Morgan–PIXY.',
  },
  {
    href: '/release-date',
    label: 'Release Date & Platforms',
    desc: 'October 2, 2026 — full launch details, early access, and regional timing.',
  },
  {
    href: '/faq',
    label: 'Frequently Asked Questions',
    desc: 'Direct answers for release, platforms, preorders, online modes and gameplay.',
  },
  {
    href: '/system-requirements',
    label: 'System Requirements',
    desc: 'What PC hardware you actually need — SSD and ray tracing GPU required.',
  },
  {
    href: '/pc',
    label: 'PC Guide',
    desc: 'Windows 11, ray-tracing GPU, SSD storage and the official minimum performance target.',
  },
  {
    href: '/languages',
    label: 'Languages & Dubs',
    desc: 'English and Japanese audio, 13 text languages and bonus-game localization.',
  },
  {
    href: '/preorder-bonuses',
    label: 'Preorder Bonuses',
    desc: 'F-14A and Ace Combat Zero eligibility, platform caveats and offer timing.',
  },
  {
    href: '/ace-combat-zero-bonus',
    label: 'Ace Combat Zero Bonus',
    desc: 'Why every pre-order includes The Belkan War, and how to claim it.',
  },
];
---
<BaseLayout
  title="Ace Combat 8 Wiki — Wings of Theve Guides & Aircraft"
  description="Unofficial Ace Combat 8 wiki with confirmed aircraft, platform status, editions, system requirements, mechanics, multiplayer and release guides."
  bareTitle={true}
>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">Strangereal / FCU vs Republic of Sotoa / 2029</span>
      <h1>ACE COMBAT 8<br />WINGS OF THEVE</h1>
      <CountdownHero />
      <p class="hero__sub">
        Everything you need before you take the name "Wings of Theve" — aircraft, editions,
        new systems, and multiplayer, tracked and updated all the way to launch.
      </p>
      <div class="hero__cta">
        <a href="/aircraft" class="btn">Browse Aircraft</a>
        <a href="/editions" class="btn btn--ghost">Compare Editions</a>
      </div>
    </div>
  </section>

  <HudStrip />

  <section class="container nav-section">
    <span class="eyebrow">Guide sections</span>
    <div class="card-grid">
      {navCards.map((c) => (
        <a href={c.href} class="card nav-card">
          <h3>{c.label}</h3>
          <p>{c.desc}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 72px 0 0;
  }
  .hero__sub {
    max-width: 560px;
    font-size: 1.05rem;
    margin: 18px 0 32px;
  }
  .hero__cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }
  .nav-section {
    padding: 64px 0;
  }
  .nav-card {
    text-decoration: none;
    color: var(--text-primary);
    display: block;
  }
  .nav-card:hover { text-decoration: none; }
  .nav-card p { font-size: 0.9rem; margin: 0; }
</style>
