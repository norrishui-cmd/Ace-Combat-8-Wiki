---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { gameplayGuides } from '../../data/gameplayGuides';

export function getStaticPaths() {
  return gameplayGuides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}
const { guide } = Astro.props;
const related = gameplayGuides.filter((item) => item.slug !== guide.slug).slice(0, 3).map((item) => ({
  href: `/gameplay/${item.slug}`, label: item.title, desc: item.answer,
}));
const faqJsonLd = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: guide.faqs.map((faq: { q: string; a: string }) => ({
    '@type': 'Question', name: faq.q, acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
---
<BaseLayout title={guide.searchTitle} description={guide.description}>
  <Breadcrumbs items={[{ label: 'Gameplay', href: '/gameplay' }, { label: guide.title }]} />
  <article class="container article">
    <span class="badge badge--confirmed">Confirmed mechanic</span>
    <h1>{guide.title}</h1>
    <p class="direct-answer" data-concrete-answer>{guide.answer}</p>
    <div class="card fact-grid">
      {guide.facts.map((fact) => <div class="fact"><span class="mono">{fact.label}</span><strong>{fact.value}</strong></div>)}
    </div>
    {guide.sections.map((section) => (
      <section>
        <h2>{section.heading}</h2>
        {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        {section.bullets && <ul>{section.bullets.map((bullet) => <li>{bullet}</li>)}</ul>}
      </section>
    ))}
    <h2>{guide.title} FAQ</h2>
    <div class="faq-list">{guide.faqs.map((faq) => <section class="card"><h3>{faq.q}</h3><p>{faq.a}</p></section>)}</div>
    <aside class="source-note">
      <p class="mono">Evidence reviewed: July 18, 2026</p>
      <ul>{guide.sources.map((source) => <li><a href={source.href} rel="nofollow">{source.label}</a></li>)}</ul>
    </aside>
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <RelatedLinks heading="Continue planning your sortie" items={related} />
</BaseLayout>

<style>
  .article { padding: 56px 0 72px; max-width: 780px; }
  .article h1 { margin-top: 12px; }
  .article h2 { margin-top: 40px; }
  .article p, .article li { font-size: .98rem; }
  .direct-answer { font-size: 1.08rem !important; border-left: 3px solid var(--hud-amber); padding-left: 18px; }
  .fact-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; margin: 28px 0; padding: 0; }
  .fact { padding: 18px; border-bottom: var(--border-thin); }
  .fact:nth-child(odd) { border-right: var(--border-thin); }
  .fact:nth-last-child(-n+2) { border-bottom: 0; }
  .fact span { display: block; color: var(--text-secondary); font-size: .68rem; text-transform: uppercase; margin-bottom: 6px; }
  .faq-list { display: grid; gap: 14px; }
  .faq-list h3 { font-size: 1rem; }
  .faq-list p { margin: 0; }
  .source-note { margin-top: 40px; padding-top: 20px; border-top: var(--border-thin); }
  .source-note p, .source-note li { font-size: .8rem; }
  @media (max-width: 560px) {
    .fact-grid { grid-template-columns: 1fr; }
    .fact, .fact:nth-child(odd), .fact:nth-last-child(-n+2) { border-right: 0; border-bottom: var(--border-thin); }
    .fact:last-child { border-bottom: 0; }
  }
</style>

