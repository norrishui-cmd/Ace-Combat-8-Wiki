---
import BaseLayout from '../layouts/BaseLayout.astro'; import Breadcrumbs from '../components/Breadcrumbs.astro'; import TabNews from '../components/TabNews.astro'; import {faqGuides,faqCategoryMeta,getFaqs} from '../data/faqGuides';
const order=['general','aircraft','gameplay','platforms','characters','story','editions','pc'] as const; const list={'@context':'https://schema.org','@type':'ItemList',name:'Ace Combat 8 frequently asked questions',numberOfItems:faqGuides.length,itemListElement:faqGuides.map((x,i)=>({'@type':'ListItem',position:i+1,name:x.question,url:new URL(`/faq/${x.slug}`,Astro.site).href}))};
---
<BaseLayout title="50 Frequently Asked Questions" description="Fifty evidence-checked Ace Combat 8 answers covering release, aircraft, gameplay, platforms, characters, story, editions and PC requirements."><Breadcrumbs items={[{label:'FAQ'}]} /><article class="container article"><span class="eyebrow">50 real questions · 50 evidence-checked answers</span><h1>Ace Combat 8 FAQ</h1><p class="direct-answer" data-concrete-answer>This FAQ contains 50 distinct player questions. Every short answer links to a dedicated evidence page with an official source, explanation and clear boundary for details that remain unannounced.</p><nav class="jump" aria-label="FAQ topics">{order.map(category=><a href={`#${category}`}>{faqCategoryMeta[category].label} ({getFaqs(category).length})</a>)}</nav>{order.map(category=><section id={category}><div class="section-head"><div><span class="mono">{getFaqs(category).length} questions</span><h2>{faqCategoryMeta[category].label} FAQ</h2></div><a href={faqCategoryMeta[category].hub}>Open {faqCategoryMeta[category].label} guide →</a></div><div class="faq-grid">{getFaqs(category).map(item=><a class="card" href={`/faq/${item.slug}`}><h3>{item.question}</h3><p>{item.answer}</p><span class="mono">Full evidence →</span></a>)}</div></section>)}</article><script type="application/ld+json" set:html={JSON.stringify(list)} /><TabNews category="faq" /></BaseLayout>
<style>.article{padding:56px 0 72px;max-width:1050px}.direct-answer{max-width:780px;font-size:1.08rem;border-left:3px solid var(--hud-amber);padding-left:18px}.jump{display:flex;flex-wrap:wrap;gap:10px;margin:28px 0 44px}.jump a{font:.75rem var(--font-mono);border:var(--border-thin);padding:8px 10px}.article>section{scroll-margin-top:90px;margin-top:48px}.section-head{display:flex;justify-content:space-between;align-items:end;gap:16px}.section-head h2{margin:5px 0 0}.section-head .mono{color:var(--radar-green);font-size:.7rem}.faq-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-top:20px}.card{color:var(--text-primary);text-decoration:none}.card h3{font-size:1rem}.card p{font-size:.86rem}.card span{color:var(--hud-amber);font-size:.7rem}@media(max-width:700px){.faq-grid{grid-template-columns:1fr}.section-head{align-items:start;flex-direction:column}}</style>
