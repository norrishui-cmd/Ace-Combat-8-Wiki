---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { platformGuides } from '../data/platformGuides';

const groups = [
  {
    heading: 'Release and purchase',
    links: [
      { href: '/release-date', label: 'When does Ace Combat 8 release?', answer: 'October 2, 2026; Deluxe digital preorder early access starts September 28.' },
      { href: '/editions', label: 'Which edition should I buy?', answer: 'Compare Standard, Deluxe, and the physical Joker Flight Pack.' },
      { href: '/ace-combat-zero-bonus', label: 'How does the Ace Combat Zero bonus work?', answer: 'It is a preorder bonus alongside the playable F-14A.' },
      { href: '/ace-pass', label: 'Is the Ace Pass free?', answer: 'The base track is free; Premium and Premium Plus are paid tiers.' },
    ],
  },
  {
    heading: 'Platforms and performance',
    links: platformGuides.map((guide) => ({ href: `/platforms/${guide.slug}`, label: `Is Ace Combat 8 on ${guide.shortName}?`, answer: guide.answer })),
  },
  {
    heading: 'Gameplay and online',
    links: [
      { href: '/getting-started', label: 'Is Ace Combat 8 beginner-friendly?', answer: 'Start with the control, missile-warning, turning, and loadout fundamentals.' },
      { href: '/multiplayer', label: 'Does Ace Combat 8 have multiplayer and co-op?', answer: 'Yes. Ace Combat Online includes a social lobby, co-op, competitive play, and cross-platform support.' },
      { href: '/ace-style-system', label: 'What is Ace Style?', answer: 'Mission actions shape the player’s pilot identity and parts of the story presentation.' },
      { href: '/aircraft', label: 'Which aircraft are confirmed?', answer: 'Browse the evidence-checked aircraft database.' },
    ],
  },
];
---
<BaseLayout
  title="FAQ — Release, Platforms, Multiplayer & Preorders"
  description="Direct answers to Ace Combat 8 questions about release date, PS5 and Xbox support, PC and Steam Deck, Switch 2, editions, Ace Pass, multiplayer, and aircraft."
>
  <Breadcrumbs items={[{ label: 'FAQ' }]} />
  <article class="container article article--wide">
    <span class="eyebrow">Quick answers with evidence</span>
    <h1>Ace Combat 8 FAQ</h1>
    <p class="intro">
      Find the short answer first, then open the linked guide for sources, limitations, and
      purchase advice. Status-sensitive answers were checked July 17, 2026.
    </p>
    {groups.map((group) => (
      <section>
        <h2>{group.heading}</h2>
        <div class="faq-grid">
          {group.links.map((item) => (
            <a class="card faq-card" href={item.href}>
              <h3>{item.label}</h3>
              <p>{item.answer}</p>
              <span class="mono">Read full answer →</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </article>
</BaseLayout>

<style>
  .article { padding: 56px 0 80px; }
  .article--wide { max-width: 960px; }
  .intro { max-width: 720px; font-size: 1.05rem; }
  .article h2 { margin-top: 44px; }
  .faq-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .faq-card { color: var(--text-primary); text-decoration: none; }
  .faq-card:hover { text-decoration: none; }
  .faq-card h3 { font-size: 1rem; }
  .faq-card p { font-size: .88rem; }
  .faq-card span { color: var(--hud-amber); font-size: .75rem; }
  @media (max-width: 700px) { .faq-grid { grid-template-columns: 1fr; } }
</style>
