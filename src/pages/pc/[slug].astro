---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Breadcrumbs from '../../components/Breadcrumbs.astro'; import RelatedLinks from '../../components/RelatedLinks.astro'; import {pcGuides,pcSource} from '../../data/pcGuides';
export function getStaticPaths(){return pcGuides.map(guide=>({params:{slug:guide.slug},props:{guide}}))} const {guide}=Astro.props; const faq={'@context':'https://schema.org','@type':'FAQPage',mainEntity:guide.faqs.map(x=>({'@type':'Question',name:x.q,acceptedAnswer:{'@type':'Answer',text:x.a}}))}; const related=pcGuides.filter(x=>x.slug!==guide.slug).slice(0,3).map(x=>({href:`/pc/${x.slug}`,label:x.title,desc:x.answer}));
---
<BaseLayout title={guide.title} description={guide.description}><Breadcrumbs items={[{label:'PC Guide',href:'/pc'},{label:guide.title}]} /><article class="container article"><span class="badge badge--confirmed">Official PC requirement</span><h1>{guide.title}</h1><p class="direct-answer" data-concrete-answer>{guide.answer}</p><div class="card facts">{guide.facts.map(f=><div><span>{f.label}</span><strong>{f.value}</strong></div>)}</div>{guide.sections.map(s=><section><h2>{s.heading}</h2>{s.paragraphs.map(p=><p>{p}</p>)}</section>)}<h2>{guide.title} FAQ</h2><div class="faq">{guide.faqs.map(x=><section class="card"><h3>{x.q}</h3><p>{x.a}</p></section>)}</div><aside class="source"><p class="mono">Evidence reviewed: July 18, 2026</p><a href={pcSource.href} rel="nofollow">{pcSource.label}</a></aside></article><script type="application/ld+json" set:html={JSON.stringify(faq)} /><RelatedLinks heading="Check the rest of your PC" items={related} /></BaseLayout>
<style>.article{padding:56px 0 72px;max-width:780px}.article h1{margin-top:12px}.article h2{margin-top:40px}.direct-answer{font-size:1.08rem;border-left:3px solid var(--hud-amber);padding-left:18px}.facts{display:grid;grid-template-columns:repeat(3,1fr);padding:0;margin:28px 0}.facts div{padding:18px;border-right:var(--border-thin)}.facts div:last-child{border:0}.facts span{display:block;color:var(--text-secondary);font: .68rem var(--font-mono);text-transform:uppercase;margin-bottom:6px}.faq{display:grid;gap:14px}.faq h3{font-size:1rem}.faq p{margin:0}.source{margin-top:40px;padding-top:20px;border-top:var(--border-thin);font-size:.8rem}@media(max-width:560px){.facts{grid-template-columns:1fr}.facts div{border-right:0;border-bottom:var(--border-thin)}}</style>
