---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Breadcrumbs from '../../components/Breadcrumbs.astro'; import RelatedLinks from '../../components/RelatedLinks.astro'; import TabNews from '../../components/TabNews.astro'; import {pcGuides} from '../../data/pcGuides';
const list={'@context':'https://schema.org','@type':'ItemList',name:'Ace Combat 8 PC guides',itemListElement:pcGuides.map((g,i)=>({'@type':'ListItem',position:i+1,name:g.title,url:new URL(`/pc/${g.slug}`,Astro.site).href}))};
---
<BaseLayout title="PC Guide — Specs, SSD & Performance" description="Ace Combat 8 PC guide covering Windows 11, ray-tracing GPU, 125GB SSD and the official upscaled 1080p 30fps minimum target."><Breadcrumbs items={[{label:'PC Guide'}]} /><article class="container article"><span class="eyebrow">Official Steam requirements</span><h1>Ace Combat 8 PC Guide</h1><p class="direct-answer" data-concrete-answer>The PC minimum combines Windows 11 64-bit, 16GB RAM, an RTX 2060 or RX 6600 XT-class listed GPU with hardware ray tracing, and 125GB on an SSD. Its estimated target is upscaled 1080p, 30fps and Low settings; recommended specifications remain TBD.</p><div class="card-grid">{pcGuides.map(g=><a class="card guide" href={`/pc/${g.slug}`}><h2>{g.title}</h2><p>{g.answer}</p><span class="mono">Open PC guide →</span></a>)}</div></article><script type="application/ld+json" set:html={JSON.stringify(list)} /><TabNews category="pc" /><RelatedLinks items={[{href:'/system-requirements',label:'Complete Specs Table',desc:'Read the official minimum configuration in one table.'},{href:'/platforms/pc',label:'Steam Platform Guide',desc:'PC release, store and multiplayer details.'},{href:'/price',label:'Price & Editions',desc:'Compare Standard and Deluxe purchase options.'}]} /></BaseLayout>
<style>.article{padding:56px 0 72px;max-width:1000px}.direct-answer{max-width:780px;font-size:1.08rem;border-left:3px solid var(--hud-amber);padding-left:18px}.card-grid{margin-top:28px}.guide{color:var(--text-primary);text-decoration:none}.guide h2{font-size:1.15rem}.guide .mono{color:var(--hud-amber);font-size:.74rem}</style>
