---
import BaseLayout from '../../layouts/BaseLayout.astro'; import Breadcrumbs from '../../components/Breadcrumbs.astro'; import RelatedLinks from '../../components/RelatedLinks.astro'; import {faqGuides,faqCategoryMeta,getFaqs} from '../../data/faqGuides';
export function getStaticPaths(){return faqGuides.map(item=>({params:{slug:item.slug},props:{item}}))} const {item}=Astro.props; const meta=faqCategoryMeta[item.category]; const peers=getFaqs(item.category).filter(x=>x.slug!==item.slug).slice(0,3); const schema={'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:item.question,acceptedAnswer:{'@type':'Answer',text:`${item.answer} ${item.detail}`}}]};
---
<BaseLayout title={item.question} description={`${item.answer} Read the confirmed evidence, purchase or gameplay context, and what remains unannounced.`}><Breadcrumbs items={[{label:'FAQ',href:'/faq'},{label:meta.label,href:`/faq#${item.category}`},{label:item.question}]} /><article class="container article"><span class="eyebrow">Evidence checked · July 19, 2026</span><h1>{item.question}</h1><p class="direct-answer" data-concrete-answer>{item.answer}</p><section><h2>Confirmed explanation</h2><p>{item.detail}</p></section><section><h2>What is not confirmed yet</h2><p>{item.boundary}</p></section><aside class="source"><p class="mono">Primary source</p><a href={item.sourceUrl} rel="nofollow">{item.sourceLabel}</a><p>This independent answer is limited to currently published official evidence and will be revised when the source changes.</p></aside></article><script type="application/ld+json" set:html={JSON.stringify(schema)} /><RelatedLinks heading={`More ${meta.label} questions`} items={[...peers.map(x=>({href:`/faq/${x.slug}`,label:x.question,desc:x.answer})),{href:meta.hub,label:`${meta.label} Guide Hub`,desc:`Open the complete ${meta.label.toLowerCase()} guide.`}]} /></BaseLayout>
<style>.article{padding:56px 0 72px;max-width:760px}.article h1{margin-top:8px}.article h2{margin-top:38px}.direct-answer{font-size:1.1rem;border-left:3px solid var(--hud-amber);padding-left:18px}.source{margin-top:42px;padding-top:20px;border-top:var(--border-thin)}.source p{font-size:.82rem}</style>
