---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AircraftCard from '../../components/AircraftCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('aircraft');
const sorted = all.sort((a, b) => a.data.order - b.data.order);
const categories = ['Multirole', 'Air Superiority', 'Attacker', 'Interceptor'];

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: sorted.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: a.data.name,
    url: new URL(`/aircraft/${a.id}`, Astro.site).toString(),
  })),
};
---
<BaseLayout
  title="Aircraft List"
  description="Full Ace Combat 8: Wings of Theve aircraft list — Multirole, Air Superiority, Attacker, and Interceptor categories, updated as Bandai Namco confirms new planes."
>
  <Breadcrumbs items={[{ label: 'Aircraft' }]} />
  <section class="container page-head">
    <span class="eyebrow">30+ aircraft at launch, 4 categories</span>
    <h1>Aircraft List</h1>
    <p>
      Every confirmed aircraft in ACE COMBAT 8: WINGS OF THEVE, plus editor estimates for
      stats that haven't been officially detailed yet. Ratings marked
      <span class="badge badge--estimate" style="margin: 0 4px;">Est.</span>
      will be replaced with real in-game numbers within 48 hours of launch.
    </p>
  </section>

  <section class="container">
    <div class="card-grid">
      {sorted.map((a) => (
        <AircraftCard
          slug={a.id}
          name={a.data.name}
          designation={a.data.designation}
          category={a.data.category}
          unlockMethod={a.data.unlockMethod}
          confirmed={a.data.confirmed}
          summary={a.data.summary}
        />
      ))}
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />

  <RelatedLinks items={[
    { href: '/editions', label: 'Editions Compared', desc: 'See which editions unlock exclusive aircraft skins and the ADFX-02.' },
    { href: '/new-mechanics', label: 'New Mechanics', desc: 'Dual special weapons and debris damage — how loadouts changed this entry.' },
  ]} />
</BaseLayout>

<style>
  .page-head {
    padding: 56px 0 40px;
    max-width: 720px;
  }
  .page-head p { font-size: 0.95rem; }
</style>
